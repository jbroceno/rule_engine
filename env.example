# =============================================================================
# Configuración del demo Docker — Motor de Reglas de Ofertas Hipotecarias
#
# Copia este fichero a ".env" en la raíz del repo y ajusta los valores:
#     cp env.example .env          (Linux/macOS / Git Bash)
#     copy env.example .env        (Windows CMD)
#
# docker-compose.yml lee automáticamente el fichero .env de la raíz.
# =============================================================================

# --- SQL Server -------------------------------------------------------------
# Contraseña del usuario 'sa'. DEBE cumplir la política de SQL Server:
# mínimo 8 caracteres con mayúsculas, minúsculas, números y símbolos.
MSSQL_SA_PASSWORD=Demo_Rule_Engine_2026!

# Nombre de la base de datos. Es totalmente configurable: el script de
# inicialización la crea con este nombre y los scripts SQL son agnósticos
# (no hardcodean el nombre). RULE_ENGINE es solo el valor por defecto.
SQL_DB_NAME=RULE_ENGINE

# --- Puertos expuestos en el host ------------------------------------------
# SQLSERVER_PORT solo se publica en 127.0.0.1 (ver docker-compose.yml) - nunca
# accesible desde fuera del host, aunque falle el firewall del VPS.
SQLSERVER_PORT=1433
API_PORT=3000
WEB_PORT=8080
WEB_HTTPS_PORT=443

# --- TLS / HTTPS --------------------------------------------------------------
# Directorio (host) con fullchain.pem y privkey.pem. Si ambos ficheros existen
# ahi, api y web arrancan en HTTPS automaticamente; si el directorio esta vacio
# (valor por defecto), sirven HTTP normal - no rompe nada si no configuras TLS.
#
# Produccion (Let's Encrypt/certbot): copia los ficheros REALES (no symlinks -
# certbot deja "live/<dominio>/*.pem" como enlaces relativos a "archive/", que
# no resuelven bien en un bind mount parcial) a un directorio propio, p.ej.:
#   mkdir -p /opt/rule-engine/certs
#   cp -L /etc/letsencrypt/live/tu-dominio.com/fullchain.pem /opt/rule-engine/certs/
#   cp -L /etc/letsencrypt/live/tu-dominio.com/privkey.pem   /opt/rule-engine/certs/
#   SSL_CERTS_DIR=/opt/rule-engine/certs
# y repite el cp -L tras cada renovacion (o automatizalo con un hook de certbot).
SSL_CERTS_DIR=./docker/certs

# JWT Authentication
# JWT_SECRET is REQUIRED — the server will refuse to start without it.
# Use a long random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=changeme_use_a_long_random_secret_in_production
# JWT_EXPIRES_IN controls token lifetime. Defaults to 8h if not set.
JWT_EXPIRES_IN=8h

# --- Feature flags ------------------------------------------------------------
# ENABLE_SEED_RESET gates POST /api/admin/config/reset-seed (QA-only DB reset to
# a known seed state). When false/unset, the endpoint returns a generic 404 —
# indistinguishable from a route that doesn't exist — hiding its existence.
# Leave disabled in production; enable only in POC/QA environments.
ENABLE_SEED_RESET=false

# =============================================================================
# Configuración del demo Docker — Motor de Reglas de Ofertas Hipotecarias
#
# Copia este fichero a ".env" en la raíz del repo y ajusta los valores:
#     cp env.example .env          (Linux/macOS / Git Bash)
#     copy env.example .env        (Windows CMD)
#
# docker-compose.yml lee automáticamente el fichero .env de la raíz.
# =============================================================================

# --- SQL Server -------------------------------------------------------------
# Contraseña del usuario 'sa'. DEBE cumplir la política de SQL Server:
# mínimo 8 caracteres con mayúsculas, minúsculas, números y símbolos.
MSSQL_SA_PASSWORD=Demo_Rule_Engine_2026!

# Edición de SQL Server. Developer es gratuita para desarrollo/pruebas.
MSSQL_PID=Developer

# Nombre de la base de datos. Es totalmente configurable: el script de
# inicialización la crea con este nombre y los scripts SQL son agnósticos
# (no hardcodean el nombre). RULE_ENGINE es solo el valor por defecto.
SQL_DB_NAME=RULE_ENGINE

# --- Puertos expuestos en el host ------------------------------------------
SQLSERVER_PORT=1433
API_PORT=3000
WEB_PORT=8080

# JWT Authentication
# JWT_SECRET is REQUIRED — the server will refuse to start without it.
# Use a long random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=changeme_use_a_long_random_secret_in_production
# JWT_EXPIRES_IN controls token lifetime. Defaults to 8h if not set.
JWT_EXPIRES_IN=8h

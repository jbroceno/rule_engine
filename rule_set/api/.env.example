PORT=3000
NODE_ENV=development

# Base de datos POC (configurador: tablas cfg_*)
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=EngineRules
SQL_USER=sa
SQL_PASSWORD=your_password_here
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERT=true
SQL_POOL_MAX=10
SQL_POOL_MIN=0
SQL_IDLE_TIMEOUT_MS=30000
SQL_REQUEST_TIMEOUT_MS=30000

# Base de datos Workflow (tablas MRO_*)
# Si no se definen, se usará la misma conexión que la BD POC.
# Definir solo si el servidor o la BD de Workflow son diferentes.
WF_SQL_SERVER=wf-server
WF_SQL_PORT=1433
WF_SQL_DATABASE=WorkflowDB
WF_SQL_USER=wf_user
WF_SQL_PASSWORD=wf_password
WF_SQL_ENCRYPT=false
WF_SQL_TRUST_SERVER_CERT=true

# Servicio Workflow / Workflow (tests live)
WF_BASE_URL=https://wf-host/ApiRest


# JWT Authentication
# JWT_SECRET is REQUIRED � the server will refuse to start without it.
# Use a long random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=changeme_use_a_long_random_secret_in_production
# JWT_EXPIRES_IN controls token lifetime. Defaults to 8h if not set.
JWT_EXPIRES_IN=8h

ENABLE_SEED_RESET=false